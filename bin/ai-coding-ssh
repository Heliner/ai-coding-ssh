#!/usr/bin/env bash

# ============================================================
# ai-coding-ssh — Connect to a remote server with AI coding tools
#
# Automatically starts the local API proxy and creates an SSH
# reverse tunnel so the remote server can reach AI APIs.
# Supports: Claude Code, Gemini CLI, Codex CLI
# ============================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="$(cd "$SCRIPT_DIR/../lib" && pwd)"

# --- Defaults ---
PROXY_PORT="${AI_CODING_SSH_PROXY_PORT:-18080}"
REMOTE_PORT="${AI_CODING_SSH_REMOTE_PORT:-18080}"
PROXY_TOKEN="${AI_CODING_SSH_PROXY_TOKEN:-}"
PID_FILE="/tmp/ai-coding-ssh-proxy.pid"
LOG_FILE="/tmp/ai-coding-ssh-proxy.log"

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# --- Usage ---
usage() {
  cat <<'USAGE'
ai-coding-ssh — SSH with AI coding tools reverse tunnel

Supports: Claude Code (Anthropic), Gemini CLI (Google), Codex CLI (OpenAI)

Usage:
  ai-coding-ssh [options] [user@]host [-- extra_ssh_args]

Options:
  -p, --proxy-port PORT    Local proxy port (default: 18080)
  -r, --remote-port PORT   Remote tunnel port (default: 18080)
  -t, --token TOKEN        Auth token for proxy access
  -k, --keep-proxy         Don't stop proxy on exit
  -i, --identity FILE      SSH identity file
  -P, --ssh-port PORT      SSH port (default: 22)
      --install-remote      Also install Claude Code on remote server
      --no-proxy            Skip proxy, only set up tunnel (proxy already running)
  -h, --help               Show this help

Environment Variables:
  AI_CODING_SSH_PROXY_PORT   Same as --proxy-port
  AI_CODING_SSH_REMOTE_PORT  Same as --remote-port
  AI_CODING_SSH_PROXY_TOKEN  Same as --token
  ANTHROPIC_API_KEY          Anthropic API key (passed to remote if set)
  GEMINI_API_KEY             Google Gemini API key (passed to remote if set)
  GOOGLE_API_KEY             Google API key (alternative to GEMINI_API_KEY)
  OPENAI_API_KEY             OpenAI API key (passed to remote if set)

Examples:
  ai-coding-ssh user@server
  ai-coding-ssh -p 9090 user@server
  ai-coding-ssh --install-remote user@server
  ai-coding-ssh user@server -- -L 3000:localhost:3000
USAGE
}

# --- Helpers ---
info()  { echo -e "${GREEN}[✓]${NC} $*"; }
warn()  { echo -e "${YELLOW}[!]${NC} $*"; }
err()   { echo -e "${RED}[✗]${NC} $*" >&2; }

check_deps() {
  if ! command -v node &>/dev/null; then
    err "Node.js is required but not found. Install it first."
    exit 1
  fi

  local node_major
  node_major=$(node -e 'console.log(process.versions.node.split(".")[0])')
  if [ "$node_major" -lt 18 ]; then
    err "Node.js >= 18 required (found v${node_major})"
    exit 1
  fi
}

is_proxy_running() {
  if [ -f "$PID_FILE" ]; then
    local pid
    pid=$(cat "$PID_FILE")
    if kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
    rm -f "$PID_FILE"
  fi
  return 1
}

start_proxy() {
  if is_proxy_running; then
    info "Proxy already running (PID $(cat "$PID_FILE"))"
    return 0
  fi

  # Auto-detect a common upstream gateway from local env vars.
  # If OPENAI_BASE_URL or GOOGLE_GEMINI_BASE_URL points to a non-localhost host,
  # use it as PROXY_UPSTREAM so all providers route through the same gateway.
  if [ -z "${PROXY_UPSTREAM:-}" ]; then
    for var in OPENAI_BASE_URL GOOGLE_GEMINI_BASE_URL ANTHROPIC_BASE_URL; do
      local val="${!var:-}"
      if [ -n "$val" ] && [[ "$val" != *"localhost"* ]] && [[ "$val" != *"127.0.0.1"* ]]; then
        export PROXY_UPSTREAM="$val"
        info "Auto-detected upstream gateway: ${PROXY_UPSTREAM} (from \$${var})"
        break
      fi
    done
  fi

  info "Starting local proxy on 127.0.0.1:${PROXY_PORT}..."

  local proxy_args=(node "$LIB_DIR/proxy.mjs" --port "$PROXY_PORT")
  if [ -n "$PROXY_TOKEN" ]; then
    proxy_args+=(--token "$PROXY_TOKEN")
  fi
  if [ -n "${PROXY_UPSTREAM:-}" ]; then
    proxy_args+=(--upstream "$PROXY_UPSTREAM")
  fi

  "${proxy_args[@]}" >> "$LOG_FILE" 2>&1 &
  local pid=$!
  echo "$pid" > "$PID_FILE"

  # Wait for proxy to be ready
  local retries=0
  while ! curl -sf "http://127.0.0.1:${PROXY_PORT}/__health" &>/dev/null; do
    retries=$((retries + 1))
    if [ $retries -gt 30 ]; then
      err "Proxy failed to start. Check $LOG_FILE"
      kill "$pid" 2>/dev/null || true
      rm -f "$PID_FILE"
      exit 1
    fi
    sleep 0.2
  done

  info "Proxy running (PID $pid)"
}

stop_proxy() {
  if [ -f "$PID_FILE" ]; then
    local pid
    pid=$(cat "$PID_FILE")
    if kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null
      info "Proxy stopped (PID $pid)"
    fi
    rm -f "$PID_FILE"
  fi
}

install_remote_claude() {
  local ssh_target="$1"
  shift
  local ssh_opts=("$@")

  info "Installing Claude Code on remote server..."
  ssh "${ssh_opts[@]}" "$ssh_target" bash <<'REMOTE_INSTALL'
    set -e
    echo "[*] Checking for Claude Code..."
    if command -v claude &>/dev/null; then
      echo "[✓] Claude Code already installed: $(claude --version 2>/dev/null || echo 'unknown version')"
      exit 0
    fi

    echo "[*] Installing Claude Code..."
    if command -v npm &>/dev/null; then
      npm install -g @anthropic-ai/claude-code 2>/dev/null && echo "[✓] Installed via npm" && exit 0
    fi

    if command -v curl &>/dev/null; then
      curl -fsSL https://claude.sh | bash && echo "[✓] Installed via curl" && exit 0
    fi

    echo "[✗] Could not install Claude Code. Please install Node.js >= 18 first."
    exit 1
REMOTE_INSTALL
}

# --- Parse Arguments ---
SSH_TARGET=""
SSH_PORT="22"
SSH_IDENTITY=""
KEEP_PROXY=false
INSTALL_REMOTE=false
NO_PROXY=false
EXTRA_SSH_ARGS=()
PARSING_EXTRA=false

while [ $# -gt 0 ]; do
  if $PARSING_EXTRA; then
    EXTRA_SSH_ARGS+=("$1")
    shift
    continue
  fi

  case "$1" in
    -p|--proxy-port)   PROXY_PORT="$2"; shift 2 ;;
    -r|--remote-port)  REMOTE_PORT="$2"; shift 2 ;;
    -t|--token)        PROXY_TOKEN="$2"; shift 2 ;;
    -k|--keep-proxy)   KEEP_PROXY=true; shift ;;
    -i|--identity)     SSH_IDENTITY="$2"; shift 2 ;;
    -P|--ssh-port)     SSH_PORT="$2"; shift 2 ;;
    --install-remote)  INSTALL_REMOTE=true; shift ;;
    --no-proxy)        NO_PROXY=true; shift ;;
    -h|--help)         usage; exit 0 ;;
    --)                PARSING_EXTRA=true; shift ;;
    -*)                err "Unknown option: $1"; usage; exit 1 ;;
    *)                 SSH_TARGET="$1"; shift ;;
  esac
done

if [ -z "$SSH_TARGET" ]; then
  err "Missing SSH target. Usage: ai-coding-ssh [options] user@host"
  exit 1
fi

# --- Main ---
check_deps

# Build SSH options
SSH_OPTS=(-o "ServerAliveInterval=30" -o "ServerAliveCountMax=3")
[ "$SSH_PORT" != "22" ] && SSH_OPTS+=(-p "$SSH_PORT")
[ -n "$SSH_IDENTITY" ] && SSH_OPTS+=(-i "$SSH_IDENTITY")

# Install Claude Code on remote if requested
if $INSTALL_REMOTE; then
  install_remote_claude "$SSH_TARGET" "${SSH_OPTS[@]}"
fi

# Start local proxy
if ! $NO_PROXY; then
  start_proxy
fi

# Set up cleanup
if ! $KEEP_PROXY && ! $NO_PROXY; then
  trap 'stop_proxy' EXIT
fi

# Build remote env file content — multi-provider
# Written to a temp file on the remote and sourced AFTER shell rc files,
# so it overrides any hardcoded BASE_URL in .bashrc/.zshrc.
REMOTE_ENV_LINES="export ANTHROPIC_BASE_URL=http://localhost:${REMOTE_PORT}"
REMOTE_ENV_LINES="${REMOTE_ENV_LINES}
export GOOGLE_GEMINI_BASE_URL=http://localhost:${REMOTE_PORT}/gemini"
REMOTE_ENV_LINES="${REMOTE_ENV_LINES}
export OPENAI_BASE_URL=http://localhost:${REMOTE_PORT}/openai"

if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
  REMOTE_ENV_LINES="${REMOTE_ENV_LINES}
export ANTHROPIC_API_KEY='${ANTHROPIC_API_KEY}'"
fi
if [ -n "${GEMINI_API_KEY:-}" ]; then
  REMOTE_ENV_LINES="${REMOTE_ENV_LINES}
export GEMINI_API_KEY='${GEMINI_API_KEY}'"
fi
if [ -n "${GOOGLE_API_KEY:-}" ]; then
  REMOTE_ENV_LINES="${REMOTE_ENV_LINES}
export GOOGLE_API_KEY='${GOOGLE_API_KEY}'"
fi
if [ -n "${OPENAI_API_KEY:-}" ]; then
  REMOTE_ENV_LINES="${REMOTE_ENV_LINES}
export OPENAI_API_KEY='${OPENAI_API_KEY}'"
fi
if [ -n "$PROXY_TOKEN" ]; then
  REMOTE_ENV_LINES="${REMOTE_ENV_LINES}
export AI_CODING_SSH_PROXY_TOKEN='${PROXY_TOKEN}'"
fi

info "Connecting to ${CYAN}${SSH_TARGET}${NC} with reverse tunnel :${REMOTE_PORT} → :${PROXY_PORT}"
echo ""
echo -e "  ${CYAN}Remote server will have:${NC}"
echo -e "    ANTHROPIC_BASE_URL=http://localhost:${REMOTE_PORT}          (Claude Code)"
echo -e "    GOOGLE_GEMINI_BASE_URL=http://localhost:${REMOTE_PORT}/gemini  (Gemini CLI)"
echo -e "    OPENAI_BASE_URL=http://localhost:${REMOTE_PORT}/openai      (Codex CLI)"
echo ""

# Strategy: write env to /tmp/.ai-proxy-env on remote, then start a shell
# that sources it AFTER all rc files (.bashrc/.zshrc) have loaded.
#
# - zsh:  rc load order is .zshenv → .zprofile → .zshrc → .zlogin
#         We use ZDOTDIR to symlink original rc files and add our env in .zlogin (last).
# - bash: We use --rcfile with a custom rc that sources ~/.bashrc first, then our env.

# Build the remote bootstrap script
read -r -d '' REMOTE_BOOTSTRAP <<'BOOTSTRAP_TMPL' || true
# --- Write proxy env to temp file ---
cat > /tmp/.ai-proxy-env << 'ENVEOF'
__REMOTE_ENV_LINES__
ENVEOF

SHELL_NAME=$(basename "$SHELL")

if [ "$SHELL_NAME" = "zsh" ]; then
  # zsh: use ZDOTDIR so .zlogin (loaded last) sources our env
  mkdir -p /tmp/.ai-proxy-zsh
  for f in .zshenv .zprofile .zshrc; do
    [ -f "$HOME/$f" ] && ln -sf "$HOME/$f" "/tmp/.ai-proxy-zsh/$f"
  done
  cat > /tmp/.ai-proxy-zsh/.zlogin << 'ZEOF'
[ -f ~/.zlogin ] && source ~/.zlogin
source /tmp/.ai-proxy-env
ZEOF
  exec env ZDOTDIR=/tmp/.ai-proxy-zsh zsh -li
else
  # bash: use --rcfile to source ~/.bashrc first, then our env
  cat > /tmp/.ai-proxy-bashrc << 'BEOF'
[ -f ~/.bashrc ] && source ~/.bashrc
source /tmp/.ai-proxy-env
BEOF
  exec bash --rcfile /tmp/.ai-proxy-bashrc -i
fi
BOOTSTRAP_TMPL

# Inject actual env lines into the template
REMOTE_BOOTSTRAP="${REMOTE_BOOTSTRAP//__REMOTE_ENV_LINES__/$REMOTE_ENV_LINES}"

# SSH with reverse tunnel
ssh \
  -R "${REMOTE_PORT}:127.0.0.1:${PROXY_PORT}" \
  "${SSH_OPTS[@]}" \
  ${EXTRA_SSH_ARGS[@]+"${EXTRA_SSH_ARGS[@]}"} \
  "$SSH_TARGET" \
  -t "$REMOTE_BOOTSTRAP"
